# ── AI Agent Configuration ──────────────────────────────────────────

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# GitHub API (required for GitHub tools)
# Create a token at: https://github.com/settings/tokens (needs repo, issues scopes)
GITHUB_TOKEN=your_github_token_here

# Default repo if none specified
GITHUB_DEFAULT_REPO=

# Whisper model size: tiny | base | small | medium | large
#   tiny  = fastest, least accurate (~1GB VRAM)
#   base  = good balance (~1GB VRAM)
#   small = better accuracy (~2GB VRAM)
#   large = best accuracy (~10GB VRAM)
WHISPER_MODEL=tiny

# Path to MCP servers config (list of external MCP servers to connect)
# Default: mcp_servers.json in project root
MCP_SERVERS_CONFIG=mcp_servers.json
